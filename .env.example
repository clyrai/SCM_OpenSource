# SleepAI Configuration
# Copy this file to .env and modify values as needed

# =============================================================================
# LLM Configuration
# =============================================================================

# Ollama model to use for concept extraction and chat
# Available options: llama3.2:latest, qwen3.5:4b, moondream:latest, mistral:latest
LLM_MODEL=llama3.2:latest

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# LLM timeout in seconds
LLM_TIMEOUT=120

# LLM provider: "ollama" (local) or "openai" (cloud)
LLM_PROVIDER=ollama

# =============================================================================
# Memory Configuration
# =============================================================================

# Working memory capacity (human short-term memory = 7±2)
WORKING_MEMORY_CAPACITY=7

# Minimum importance score to keep a memory (below = forget candidate)
IMPORTANCE_THRESHOLD=0.3

# Novelty threshold for detecting new concepts
NOVELTY_THRESHOLD=0.7

# =============================================================================
# Sleep Configuration
# =============================================================================

# Sleep triggers when entropy exceeds this value (0.0-1.0)
SLEEP_ENTROPY_THRESHOLD=0.9

# Sleep triggers when conflict density exceeds this value
SLEEP_CONFLICT_THRESHOLD=0.3

# Maximum seconds between sleep cycles
SLEEP_INTERVAL_MAX=3600

# Synaptic downscaling factor during NREM (0.0-1.0)
NREM_DOWNSCALE_FACTOR=0.8

# Number of dreams to generate during REM
REM_DREAM_COUNT=5

# Enable auto-sleep during chat
AUTO_SLEEP_ENABLED=true

# Check for sleep every N messages
AUTO_SLEEP_INTERVAL=5

# =============================================================================
# HME Phase 4: SleepKernelV2 (Micro + Deep)
# =============================================================================

# Enable lightweight micro-sleep cycles during active conversation
MICRO_SLEEP_ENABLED=true

# Trigger micro-sleep every N turns (or sooner on entropy spike)
MICRO_SLEEP_INTERVAL_TURNS=4

# Entropy threshold for micro-sleep
MICRO_SLEEP_ENTROPY_THRESHOLD=0.82

# Light decay factor for weak traces during micro-sleep
MICRO_SLEEP_LIGHT_DECAY_FACTOR=0.97

# Max number of unstable traces replayed per micro-sleep
MICRO_SLEEP_REPLAY_TOP_K=12

# Deep-sleep trigger: minimum idle seconds
DEEP_SLEEP_MIN_IDLE_SECONDS=900

# Deep-sleep trigger: long-session turn threshold
DEEP_SLEEP_SESSION_TURNS=24

# Deep-sleep trigger: pressure threshold (entropy/conflict composite)
DEEP_SLEEP_PRESSURE_THRESHOLD=0.93

# Global proportional downscale factor applied in deep-sleep
DEEP_SLEEP_GLOBAL_DOWNSCALE_FACTOR=0.90

# Enable REM-like synthesis pass during deep-sleep
DEEP_SLEEP_ENABLE_SYNTHESIS=true

# =============================================================================
# HME Phase 5: Forgetting Dynamics + Contradiction Versioning
# =============================================================================

# Retention weighting for memory decay decisions
FORGETTING_WEIGHT_GRASP=0.22
FORGETTING_WEIGHT_SALIENCE=0.24
FORGETTING_WEIGHT_REHEARSAL=0.18
FORGETTING_WEIGHT_ASSOCIATION=0.18
FORGETTING_WEIGHT_RECENCY=0.12
FORGETTING_WEIGHT_INTERFERENCE=0.22

# Retention thresholds
FORGETTING_SUPPRESS_THRESHOLD=0.32
FORGETTING_ARCHIVE_THRESHOLD=0.16

# Base decay used to derive trace-specific lambda values
FORGETTING_BASE_DECAY=0.04

# Versioning similarity threshold for contradiction-safe updates
CONTRADICTION_VERSION_SIMILARITY=0.70
CONTRADICTION_VERSION_CONTEXT_BONUS=0.12

# =============================================================================
# HME Phase 6 Safety Nets (recommend enabling for production)
# =============================================================================

# Min salience score below which forgetting is not allowed to demote a
# concept's state. Set to 0.5 to enable; 0.0 (default) preserves legacy
# behavior. Without this, a uniform-salience encoder + saturated entropy
# will drive the forgetting dynamics to archive everything.
FORGETTING_PROTECT_SALIENCE=0.0

# Min rehearsal count before a concept can be archived. New concepts that
# haven't survived a sleep cycle are kept in SUPPRESSED rather than ARCHIVED
# until this count is met. Set to 1 for a gentler forgetting regime.
FORGETTING_MIN_REHEARSAL_BEFORE_ARCHIVE=0

# Cooldown gates: minimum number of conversation turns between consecutive
# auto-sleep firings. Stops the "sleep storm" failure mode where saturated
# entropy fires deep-sleep on every check.
DEEP_SLEEP_COOLDOWN_TURNS=12
MICRO_SLEEP_COOLDOWN_TURNS=2

# Enable sleep-time paraphrase: rewrites consolidated concept descriptions
# into clean fact form ("Caroline says: I work at GreenLeaf" → "Caroline
# works at GreenLeaf."). Dramatically improves token-overlap retrieval on
# benchmarks like LoCoMo. Default backend is heuristic (free); pass an LLM
# instance to DeepSleep(paraphraser=...) to use cloud paraphrase.
DEEP_SLEEP_ENABLE_PARAPHRASE=false

# =============================================================================
# Phase 7: Autonomous Learning (IdleLearner daemon)
# =============================================================================
# Master switch for the background daemon that runs sleep cycles when sessions
# are idle. With this enabled, the agent will consolidate / abstract / prune
# memory while the user is away, so the next session opens with a "smarter"
# agent than the previous one closed with.
IDLE_LEARNER_ENABLED=false

# Seconds since last user activity before a session is considered "idle"
# and eligible for autonomous sleep. Default 600 = 10 minutes.
IDLE_LEARNER_IDLE_THRESHOLD_SECONDS=600

# Minimum seconds between consecutive autonomous sleep cycles per session.
# Default 1800 = 30 minutes. Stops the daemon from repeatedly sleeping a
# session that just slept.
IDLE_LEARNER_MIN_SLEEP_INTERVAL_SECONDS=1800

# How often the daemon's main loop wakes up to check sessions, in seconds.
# Default 60. Lower = more responsive, higher overhead. Don't go below 5.
IDLE_LEARNER_TICK_INTERVAL_SECONDS=60

# Hard upper bound on a single autonomous sleep cycle's wall-clock duration.
# If a cycle runs longer than this, a warning is logged. Default 120s.
IDLE_LEARNER_MAX_SLEEP_DURATION_SECONDS=120

# Which sleep mode the daemon fires. Options: "deep", "micro", "auto".
IDLE_LEARNER_SLEEP_MODE=deep

# Phase 7 M6: state persistence so the daemon survives API restarts.
# When enabled, the daemon snapshots per-session activity timestamps and
# recent cycle history to a JSON file, restoring on startup.
IDLE_LEARNER_PERSIST_ENABLED=true
IDLE_LEARNER_STATE_PATH=data/idle_learner_state.json
IDLE_LEARNER_PERSIST_EVERY_N_TICKS=5

# Phase 7 M6: Lifecycle policy (power-state + CPU gating)
# When enabled, the daemon checks system state before firing heavy work.
# Battery policy: blocks deep-sleep on battery below MIN_BATTERY_PERCENT
# unless plugged in. CPU policy: blocks if system CPU > MAX_CPU_PERCENT.
LIFECYCLE_POLICY_ENABLED=true
LIFECYCLE_POLICY_MIN_BATTERY_PERCENT=30
LIFECYCLE_POLICY_ALLOW_WHEN_PLUGGED_IN=true
LIFECYCLE_POLICY_MAX_CPU_PERCENT=80
LIFECYCLE_POLICY_CPU_SAMPLE_SECONDS=0.2
# If true, missing psutil → blocking. If false (default), missing → allow.
LIFECYCLE_POLICY_REQUIRE_PSUTIL=false

# =============================================================================
# Phase 7: Cross-Session Memory Pool
# =============================================================================
# When enabled, sleep cycles see episodes from the last N sessions (not just
# the current session's working memory). This is what gives the agent
# continuity of self across days — "yesterday's experiences inform today's
# patterns." Default off for backward compatibility.
CROSS_SESSION_POOL_ENABLED=false

# Number of recent sessions (besides the current one) to pull from.
CROSS_SESSION_POOL_MAX_SESSIONS=5

# Look-back time window in hours. 168 = 7 days.
CROSS_SESSION_POOL_LOOKBACK_HOURS=168

# Per-session cap so a chatty session can't dominate the pool.
CROSS_SESSION_POOL_MAX_EPISODES_PER_SESSION=30

# Total cap across all borrowed episodes per sleep cycle.
CROSS_SESSION_POOL_MAX_TOTAL_BORROWED=100

# =============================================================================
# Phase 7: REM Schema Extraction
# =============================================================================
# When enabled, deep-sleep detects recurring patterns across episodes and
# emits ABSTRACT-type "schema" concepts. The wake-summary endpoint surfaces
# these to the user as "while you were away, I noticed: ...".
DEEP_SLEEP_ENABLE_SCHEMAS=false

# An entity must appear in at least this many distinct episodes to count as
# a "recurring topic" pattern.
SCHEMA_MIN_REPETITIONS=3

# Two entities must co-occur in at least this many episodes before a
# co-occurrence schema is emitted.
SCHEMA_COOCCURRENCE_MIN=2

# Hard cap on schemas emitted per sleep cycle.
SCHEMA_MAX_PER_CYCLE=12

# Max episodes the extractor inspects per cycle.
SCHEMA_MAX_EPISODES_WINDOW=200

# Tolerance window (hours) for temporal-cadence detection. 0 disables it.
SCHEMA_TEMPORAL_WINDOW_HOURS=24

# =============================================================================
# Phase 7: Curiosity Engine (A-Z autonomous learning)
# =============================================================================
# When enabled, deep-sleep detects entity gaps (entities the user mentioned
# but the agent doesn't know about) and ingests briefs from configured
# sources. PRIVACY: default off; opt-in by source.
CURIOSITY_ENGINE_ENABLED=false

# Cap on gaps filled per sleep cycle. Bounds cost and ingestion volume.
CURIOSITY_MAX_GAPS_PER_CYCLE=3

# An entity must be mentioned at least this many times before counting as a gap.
CURIOSITY_MIN_OCCURRENCES=2

# Max chars per ingested brief. Keep short — these become Concept descriptions.
CURIOSITY_MAX_BRIEF_CHARS=280

# Source: path to a JSON dict of {entity → brief}. Empty = source disabled.
# This is the safest source: the user supplies their own glossary.
CURIOSITY_DICTIONARY_PATH=

# Source: path to a folder of plain-text/markdown notes the agent may read.
# Empty = source disabled. Files are read sequentially, first paragraph
# containing the entity wins.
CURIOSITY_LOCAL_DOCS_FOLDER=

# Source: LLM-backed brief generation. Uses LLM_PROVIDER + LLM_MODEL.
# This is the source that gives the agent autonomous knowledge generation
# (vs. just looking up the dictionary). Costs ~1 short LLM call per gap.
CURIOSITY_LLM_SOURCE_ENABLED=false

# =============================================================================
# Phase 7 (de-hardcoding): Linguistic resources
# =============================================================================
# Path to the JSON file containing all locale-specific keywords, regex
# patterns, and narrative templates. Empty = use the default English bundle
# at src/core/locales/en.json. Override to localize or domain-tune.
LINGUISTIC_CONFIG_PATH=

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL (optional — falls back to SQLite if unavailable)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sleepai

# =============================================================================
# Embedding Configuration
# =============================================================================

# Sentence transformer model for embeddings (used when SCM_EMBEDDING_BACKEND=sentence_transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimension (384 for MiniLM-L6-v2)
EMBEDDING_DIM=384

# Phase 7: Embedding backend selection
# ────────────────────────────────────
# Choose which embedding backend MeaningEncoder uses. Default keeps
# backward compatibility with the in-process sentence-transformer model.
# Switch to ollama for higher-quality retrieval (bridges question→fact
# phrasing gaps that MiniLM-L6-v2 doesn't), or to openai_compat for
# best-in-class quality at the cost of API spend + non-private memory.
#
# Values:
#   sentence_transformers (default)  — in-process MiniLM-L6-v2 (384-dim)
#   ollama                           — local Ollama HTTP server
#   openai_compat                    — any OpenAI-format /v1/embeddings endpoint
#   hash                             — deterministic offline fallback
SCM_EMBEDDING_BACKEND=sentence_transformers

# Model name for the chosen backend.
# For ollama:        nomic-embed-text (768-dim, recommended), mxbai-embed-large (1024-dim), bge-large-en
# For openai_compat: text-embedding-3-small, text-embedding-3-large, voyage-2, etc.
# Ignored for sentence_transformers + hash backends (use EMBEDDING_MODEL above).
SCM_EMBEDDING_MODEL=nomic-embed-text

# Ollama base URL (only used when SCM_EMBEDDING_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible embedding endpoint config (only used when SCM_EMBEDDING_BACKEND=openai_compat)
# SCM_EMBEDDING_BASE_URL=https://api.openai.com/v1
# SCM_EMBEDDING_API_KEY=sk-...   # or use OPENAI_API_KEY

# =============================================================================
# API Configuration
# =============================================================================

# Host to bind the API server
API_HOST=0.0.0.0

# Port for the API server
API_PORT=8000

# =============================================================================
# Session Configuration
# =============================================================================

# Enable loading previous sessions on startup
ENABLE_SESSION_PERSISTENCE=true

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log raw LLM responses (verbose)
LOG_LLM_RAW=false
